###############################################################################
# ABEM – Environment Variables Reference
# Copy this file to .env (dev) or .env.prod (production) and fill in values.
# NEVER commit .env or .env.prod to version control.
###############################################################################

# ── Django ─────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=your-super-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_DB=abem
POSTGRES_USER=abem_user
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_SSL_MODE=prefer

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Cloudinary (file storage) ─────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Email (SMTP) ───────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=ABEM <noreply@abem.app>

# ── Firebase (FCM push notifications) ─────────────────────────────────────────
FIREBASE_CREDENTIALS_PATH=/app/firebase-credentials.json

# ── CORS (comma-separated allowed origins) ────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Sentry (error tracking – production only) ─────────────────────────────────
SENTRY_DSN=

# ── Frontend (Vite) ────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000/api/v1
