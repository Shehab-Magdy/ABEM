{
  // ── Python test discovery (abem-automation) ──────────────────────────────
  "python.defaultInterpreterPath": "${workspaceFolder}/abem-automation/.venv/bin/python",
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "python.testing.cwd": "${workspaceFolder}/abem-automation",
  "python.testing.pytestPath": "${workspaceFolder}/abem-automation/.venv/bin/pytest",
  "python.testing.pytestArgs": [
    "tests",
    "--no-header",
    "-p", "no:warnings"
  ]
}
